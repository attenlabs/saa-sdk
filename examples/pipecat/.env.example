# SAA × Pipecat, reference adapter env file.
#
# Copy to .env and fill in real values. Loaded by python-dotenv at process
# start. Both bot.py and overlay_server.py read from the same file.

# ───────────────────────────────────────────────────────────────────────────
# Required
# ───────────────────────────────────────────────────────────────────────────

# Get a token at https://attentionlabs.ai/dashboard
ATTENLABS_TOKEN=

# STT, https://console.deepgram.com
DEEPGRAM_API_KEY=

# LLM, https://platform.openai.com
OPENAI_API_KEY=

# TTS, https://play.cartesia.ai
CARTESIA_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Optional, SAA tuning
# ───────────────────────────────────────────────────────────────────────────

# Device-directed confidence threshold, 0..1. Lower = more permissive.
# Default 0.7. Try 0.65 in rooms with heavy crosstalk.
SAA_THRESHOLD=0.7

# Forward upstream camera frames to SAA (multimodal mode). True by default
# on cloud transports that ship video. No-op on phone bridges.
SAA_FORWARD_VIDEO=true

# Enable barge-in: a fresh directed utterance during bot speech pushes an
# InterruptionFrame upstream. Default true.
SAA_BARGE_IN=true

# Emit SAA* sidecar frames (SAAPredictionFrame, SAADecisionFrame,
# SAAStatsFrame, SAAConnectionFrame). Required by overlay_server.py.
SAA_EMIT_SIDECAR=true

# Forward upstream audio unchanged until the SAA warmup completes (~1 s
# after connect). Default false (fail-closed: silence until warm).
SAA_PASSTHROUGH_WARMUP=false

# Local-mic mode only, toggle webcam capture by the SDK.
SAA_ENABLE_VIDEO=true

# Override the SAA server URL. Leave blank to use production.
# ATTENLABS_URL=wss://server.attentionlabs.ai/ws

# ───────────────────────────────────────────────────────────────────────────
# Optional, LLM / TTS tuning
# ───────────────────────────────────────────────────────────────────────────

OPENAI_MODEL=gpt-4o-mini
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# ───────────────────────────────────────────────────────────────────────────
# Optional, overlay SSE shim (overlay_server.py)
# ───────────────────────────────────────────────────────────────────────────

# Port the overlay SSE server listens on. Default 8080.
SAA_OVERLAY_PORT=8080

# Rolling window of decisions kept in memory (per subscriber). Default 100.
SAA_OVERLAY_BUFFER=100
