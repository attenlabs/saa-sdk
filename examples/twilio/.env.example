# ── Attention Labs SAA ────────────────────────────────────────────────
# Get a token at https://attentionlabs.ai/dashboard
ATTENLABS_TOKEN=

# Device-class confidence threshold (0..1). Default 0.7, raise to 0.8+
# in noisy rooms, lower to 0.6 if you want SAA to be more permissive.
SAA_THRESHOLD=0.7

# Override the inference URL (defaults to wss://server.attentionlabs.ai/ws).
# ATTENLABS_URL=wss://server.attentionlabs.ai/ws

# ── Twilio (signature validation + outbound calls) ────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public hostname Twilio dials (ngrok hostname locally; load-balancer
# hostname in production). Used to compute the wss:// URL embedded in
# TwiML and to validate Twilio signatures behind a proxy.
PUBLIC_HOSTNAME=

# Optional spoken greeting for outbound calls. Empty disables the prompt.
OUTBOUND_GREETING=

# ── Adapter tuning ────────────────────────────────────────────────────
# How long to wait for SAA's `started` (warmup-complete) signal before
# forwarding caller PCM. Raise on slow links; lower if you'd rather sacrifice
# the first 100 ms than delay the call.
SAA_WAIT_READY_SECONDS=3.0

# How long mark_responding(True) lingers after the last outbound byte so
# a sub-frame echo of the last TTS sample can't re-arm SAA. 0.0 disables.
RESPONDING_TAIL_SECONDS=0.25

# Outbound TTS pacing. Twilio recommends 20 ms = 0.02s; straying starves or
# overruns the carrier jitter buffer.
OUTBOUND_PACE_SECONDS=0.02

# Bounded outbound queue depth so a misbehaving bridge can't OOM the relay.
OUTBOUND_QUEUE_MAX=512

# ── Reference bridges (optional) ──────────────────────────────────
# Only needed when wiring one of the shipped bridges:
#   - bridge_openai_realtime.OpenAIRealtimeBridge
OPENAI_API_KEY=
#   - bridge_deepgram_openai_elevenlabs.DeepgramOpenAIElevenLabsBridge
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
