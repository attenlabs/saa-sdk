# ── Attention Labs SAA ────────────────────────────────────────────────
# Get a token at https://attentionlabs.ai/dashboard
ATTENLABS_TOKEN=

# Device-class confidence threshold (0..1). Default 0.7. Outbound AI-SDR
# calls tend to be solo callers on a phone, so 0.7 works for most
# campaigns. Raise to 0.8+ if your campaign list skews toward
# noisy-environment numbers (commute lines, retail floors).
SAA_THRESHOLD=0.7

# Override the inference URL (defaults to wss://server.attentionlabs.ai/ws).
# ATTENLABS_URL=wss://server.attentionlabs.ai/ws

# ── Twilio (signature validation + outbound calls) ────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public hostname Twilio dials when it fetches /voice/outbound TwiML.
# In local development, an ngrok tunnel hostname; in production, the
# load-balancer hostname terminating TLS in front of this server.
PUBLIC_HOSTNAME=

# ── OpenAI Realtime ───────────────────────────────────────────────────
# Required by AISDRBridge (subclass of OpenAIRealtimeBridge).
OPENAI_API_KEY=

# ── Adapter tuning (inherited from examples/twilio/.env.example) ─────
# How long to wait for SAA's `started` (warmup-complete) signal before
# forwarding caller PCM. Outbound calls open the SAA session a few
# hundred ms before the callee picks up, so 3.0s is generally safe.
SAA_WAIT_READY_SECONDS=3.0

# How long mark_responding(True) lingers after the last outbound byte
# so a sub-frame echo of the last TTS sample can't re-arm SAA. 0.0
# disables.
RESPONDING_TAIL_SECONDS=0.25

# Outbound TTS pacing. Twilio recommends 20 ms = 0.02s; straying
# starves or overruns the carrier jitter buffer.
OUTBOUND_PACE_SECONDS=0.02

# Bounded outbound queue depth so a misbehaving bridge can't OOM the
# relay.
OUTBOUND_QUEUE_MAX=512

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
