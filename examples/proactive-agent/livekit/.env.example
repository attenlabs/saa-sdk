# Inherits from ../../livekit/.env.example. Copy that first.

# ── Attention Labs SAA ────────────────────────────────────────────────
ATTENLABS_TOKEN=
SAA_THRESHOLD=0.7
SAA_GATE_MODE=pre_stt

# ── LiveKit ───────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Bridge stack ──────────────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ── Proactive worker ────────────────────────────────────────
# Override the agent's registration name on the LiveKit dispatch graph.
# Default "saa-proactive-agent". Set when running multiple proactive workers.
# AGENT_NAME=saa-proactive-agent

# ── Proactive trigger sidecar ────────────────────────────────────────
PROACTIVE_HTTP_PORT=8765
