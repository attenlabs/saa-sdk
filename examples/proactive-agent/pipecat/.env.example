# Inherits from ../../pipecat/.env.example. Copy that first, then
# layer on the proactive-specific knobs below.

# ── Attention Labs SAA ────────────────────────────────────────────────
ATTENLABS_TOKEN=
SAA_THRESHOLD=0.7

# ── Pipecat bridge stack ──────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# ── Proactive trigger sidecar ────────────────────────────────────────
# POST /trigger lands on this port. Defaults to 8765 to avoid the
# Pipecat dev transport's port (depends on the runner).
PROACTIVE_HTTP_PORT=8765
