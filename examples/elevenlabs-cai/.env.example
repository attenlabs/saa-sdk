# ── Attention Labs SAA ─────────────────────────────────────────────────
# Only the Twilio relay needs ATTENLABS_TOKEN server-side. The browser
# bundle prompts the user to paste their own token at runtime.
# Get tokens at https://attentionlabs.ai/dashboard.
ATTENLABS_TOKEN=

# Device-class confidence threshold (0..1). Default 0.7, raise to 0.8+
# in noisy rooms, lower to 0.6 if SAA feels conservative.
SAA_THRESHOLD=0.7

# How SAA gates the ElevenLabs mic in the browser app:
#   mic    , SAA's prediction drives setMicMuted (default)
#   context, never mute; only send contextual updates / client tools
#   off    , SAA is observer-only (no mic gate, no contextual updates)
SAA_GATE_MODE=mic

# ── ElevenLabs ────────────────────────────────────────────────────────
# Server-only. NEVER expose ELEVENLABS_API_KEY to the browser. The server
# mints short-lived conversation tokens / signed URLs over the
# documented xi-api-key path and passes those to the page.
ELEVENLABS_API_KEY=

# Public or private agent id. Required.
ELEVENLABS_AGENT_ID=

# Transport for the browser SDK: webrtc (default, recommended) or websocket.
# WebRTC needs /api/conversation-token; WebSocket needs /api/signed-url.
ELEVENLABS_CONNECTION_TYPE=webrtc

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Set to 1 in dev for uvicorn auto-reload.
# RELOAD=1

# ── Advanced ElevenLabs overrides (leave unset for production) ────
# These are the canonical ElevenLabs API endpoints; override only when
# pinning to a staging cluster or testing against a recorded mock.
# ELEVENLABS_WS_BASE=wss://api.elevenlabs.io/v1/convai/conversation
# ELEVENLABS_SIGNED_URL_BASE=https://api.elevenlabs.io/v1/convai/conversation/get-signed-url
# ELEVENLABS_TOKEN_URL=https://api.elevenlabs.io/v1/convai/conversation/token

# ── Twilio (only for the PSTN → ElevenLabs CAI relay path) ───────────────────
# Required for the /twilio WebSocket relay; not needed for the browser app.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# PUBLIC_HOSTNAME=  # ngrok hostname locally; load-balancer hostname in prod
