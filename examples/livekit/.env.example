# ── Attention Labs SAA ──────────────────────────────────────────
# Get a token at https://attentionlabs.ai/dashboard
ATTENLABS_TOKEN=

# Gate mode, the production default is pre_stt (true pre-ASR gate).
#   pre_stt   STT only sees device-directed audio (saves STT + LLM + TTS)
#   response  STT runs on every turn; LLM/TTS skipped on non-directed turns
SAA_GATE_MODE=pre_stt

# Device-class confidence threshold (0..1). Default 0.7, raise to 0.8+
# in noisy rooms, lower to 0.6 if you want SAA to be more permissive.
SAA_THRESHOLD=0.7

# How long a single SAA "device-directed" verdict stays open in response
# mode. Default 2.0s lines up with typical STT endpointing latency.
# Ignored when SAA_GATE_MODE=pre_stt (the gate is event-driven there).
SAA_GATE_TTL_S=2.0

# Multi-modal: subscribe to the participant camera track and forward
# JPEGs to SAA so gaze + face presence factor into the verdict. Set to
# "false" if you don't want video subscribed at all.
SAA_ENABLE_VIDEO=true
SAA_VIDEO_FPS=4
SAA_VIDEO_JPEG_QUALITY=60

# Override the inference URL (defaults to wss://server.attentionlabs.ai/ws).
# ATTENLABS_URL=wss://server.attentionlabs.ai/ws

# ── LiveKit Cloud (or self-hosted server) ───────────────────────
# Sign in at https://cloud.livekit.io to get URL + API key/secret.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── STT / LLM / TTS providers ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VOICE=alloy

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-general

# ── Worker config ──────────────────────────────────────────────
AGENT_NAME=saa-gated-assistant
LOG_LEVEL=INFO

# ── Token mint server (optional, for browser/mobile clients) ──────────
TOKEN_HOST=0.0.0.0
TOKEN_PORT=8088
TOKEN_TTL_S=3600
# Comma-separated CORS allow-list for the token mint. Default in code is
# localhost:{3000,5173,8080}. Set to your production origin(s) before deploy.
TOKEN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
