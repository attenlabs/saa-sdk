# ── Attention Labs SAA ────────────────────────────────────────────────
# Get a token at https://attentionlabs.ai/dashboard
ATTENLABS_TOKEN=

# Device-class confidence threshold (0..1). Default 0.7, raise to 0.8+
# in noisy rooms, lower to 0.6 if you want SAA to be more permissive.
SAA_THRESHOLD=0.7

# Override the inference URL (defaults to wss://server.attentionlabs.ai/ws).
# ATTENLABS_URL=wss://server.attentionlabs.ai/ws

# ── OpenAI Realtime ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=alloy

# Override only if you're hitting a non-default OpenAI endpoint.
# OPENAI_REALTIME_WS=wss://api.openai.com/v1/realtime?model=gpt-realtime
# OPENAI_SESSIONS_URL=https://api.openai.com/v1/realtime/sessions

# System prompt used by both the browser-direct session and the
# server-side ephemeral-token session. Override for your domain copy.
# OPENAI_INSTRUCTIONS="You are a helpful, concise voice assistant. Reply in one or two short sentences."

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Set to 1 in dev for uvicorn auto-reload.
# RELOAD=1
