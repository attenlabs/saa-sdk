{
  "name": "@attenlabs/saa-js",
  "version": "0.7.0",
  "author": "Attention Labs <omar@attentionlabs.ai>",
  "homepage": "https://attentionlabs.ai",
  "description": "Browser/JavaScript SDK for SAA, the addressee layer for voice agents — emits a turn_ready event per device-directed utterance so only speech meant for your agent reaches your STT, LLM, or TTS. No wake word.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./audio-processor.js": "./dist/audio-processor.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/embed-worklet.mjs",
    "build": "npx tsc && cp src/audio-processor.js dist/audio-processor.js",
    "clean": "rm -rf dist",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "voice-agents",
    "voice-ai",
    "addressee-detection",
    "device-directed-speech",
    "selective-auditory-attention",
    "turn-detection",
    "speech-recognition",
    "vad",
    "wake-word",
    "conversational-ai",
    "real-time",
    "llm",
    "stt",
    "javascript",
    "browser",
    "webrtc",
    "livekit",
    "pipecat",
    "elevenlabs",
    "twilio",
    "openai-realtime",
    "barge-in",
    "pre-stt"
  ],
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "git+https://github.com/attenlabs/saa-sdk.git", "directory": "packages/saa-js" },
  "bugs": { "url": "https://github.com/attenlabs/saa-sdk/issues" },
  "changelog": "https://github.com/attenlabs/saa-sdk/blob/main/CHANGELOG.md",
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
